POSTGRES_DB=systemforge
POSTGRES_USER=systemforge
POSTGRES_PASSWORD=systemforge

BACKEND_DATABASE_URL=postgresql+psycopg://systemforge:systemforge@postgres:5432/systemforge
BACKEND_REDIS_URL=redis://redis:6379/0
BACKEND_JWT_SECRET=replace-with-strong-secret
BACKEND_METRICS_SECRET=replace-with-metrics-secret
BACKEND_OPENAI_API_KEY=
BACKEND_OPENAI_BASE_URL=https://api.openai.com/v1
BACKEND_OPENAI_MODEL=gpt-4.1-mini
BACKEND_AUTO_CREATE_TABLES=false
BACKEND_OTEL_EXPORTER_OTLP_ENDPOINT=

FRONTEND_NEXT_PUBLIC_API_URL=/api
BACKEND_INTERNAL_URL=http://backend:8000
FRONTEND_NEXT_PUBLIC_APP_NAME=SystemForge AI

# Local demo seed account. The Docker Compose demo seeder is idempotent.
DEMO_USER_EMAIL=demo@systemforge.dev
DEMO_USER_PASSWORD=SystemForgeDemo123!
DEMO_USER_FULL_NAME=SystemForge Demo
DEMO_WORKSPACE_NAME=SystemForge Showcase
