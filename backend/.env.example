APP_NAME=SystemForge AI API
APP_ENV=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+psycopg://systemforge:systemforge@localhost:5432/systemforge
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-with-strong-secret
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=720

OPENAI_API_KEY=
# Default OpenAI; for Groq use https://api.groq.com/openai/v1 and a Groq model id.
# For local Ollama: http://localhost:11434/v1 (or http://host.docker.internal:11434/v1 from Docker).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

RATE_LIMIT_PER_MINUTE=30
AUTO_CREATE_TABLES=true
